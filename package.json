{
  "name": "e-commerce-website",
  "private": true,
  "scripts": {
    "deps:clean-drift": "node stress-test/scripts/clean-native-package-drift.cjs",
    "dev": "pnpm kill-ports && node stress-test/scripts/dev-with-medusa-first.mjs",
    "dev:parallel": "pnpm kill-ports && pnpm exec turbo dev",
    "kill-ports": "node stress-test/scripts/kill-project-ports.js",
    "commit": "git add -A && node scripts/commit/cli/index.js commit",
    "commit:dry": "node scripts/commit/cli/index.js commit --dry-run",
    "commit:cli": "node scripts/commit/cli/index.js help",
    "commit:sh": "bash scripts/commit/parallel-commit.sh",
    "commit:sh:dry": "bash scripts/commit/parallel-commit.sh --dry-run",
    "commit:all": "git add -A && git commit -m \"chore: update project files\"",
    "security:check": "node scripts/commit/cli/index.js security",
    "build": "pnpm exec turbo build",
    "lint": "pnpm exec turbo lint",
    "ci:preflight": "node scripts/ci-preflight.cjs",
    "ci:preflight:full": "node scripts/ci-preflight-full.cjs",
    "db:migrate": "pnpm --filter @apparel-commerce/database migrate",
    "db:migrate:status": "pnpm --filter @apparel-commerce/database migrate:status",
    "medusa:seed:categories": "pnpm --filter medusa seed:categories",
    "db:seed": "pnpm --filter @apparel-commerce/database seed",
    "test": "node stress-test/scripts/check-test-runtime.cjs esbuild && pnpm --filter @apparel-commerce/platform-data test && pnpm --filter @apparel-commerce/ui build && pnpm --filter @apparel-commerce/sdk test && pnpm --filter @apparel-commerce/validation test && pnpm --filter @apparel-commerce/omnichannel-policy test && pnpm --filter @apparel-commerce/rate-limits test && pnpm --filter @apparel-commerce/api test && pnpm --filter @apparel-commerce/database test && pnpm --filter @apparel-commerce/admin test && pnpm --filter @apparel-commerce/storefront test && pnpm --filter medusa test:unit && pnpm --filter medusa test:stress",
    "check:migration-boundary": "node stress-test/scripts/check-commerce-migration-boundary.mjs",
    "audit:medusa-schema:copy": "node stress-test/scripts/copy-medusa-schema-artifact.mjs",
    "check:storefront-client": "node stress-test/scripts/check-storefront-client-boundary.mjs",
    "check:admin-api-guard": "node stress-test/scripts/check-admin-api-staff-guard.mjs",
    "stress-test": "node stress-test/scripts/check-test-runtime.cjs esbuild && node stress-test/scripts/stress-test.js",
    "stress-test:quick": "node stress-test/scripts/check-test-runtime.cjs esbuild && node stress-test/scripts/stress-test.js --no-e2e --no-dogfood",
    "release-gate": "node stress-test/scripts/check-test-runtime.cjs esbuild && node stress-test/scripts/release-gate.js",
    "release-gate:full": "node stress-test/scripts/check-test-runtime.cjs esbuild && node stress-test/scripts/release-gate.js --include-e2e",
    "e2e:prep:medusa": "node stress-test/scripts/e2e-prep-medusa.mjs",
    "e2e:prep:medusa:force": "node stress-test/scripts/e2e-prep-medusa.mjs --force",
    "e2e:ensure-staff": "pnpm --filter @apparel-commerce/database e2e:ensure-staff",
    "e2e:prep": "node stress-test/scripts/e2e-prep-medusa.mjs && pnpm e2e:ensure-staff",
    "test:psp-sandbox": "node stress-test/scripts/test-psp-sandbox.cjs",
    "test:http-flow": "node stress-test/scripts/run-http-flow.cjs",
    "test:http-flow:with-webservers": "node stress-test/scripts/run-e2e.js flows/http-flow-matrix.spec.ts",
    "stress-test:checkout-providers": "pnpm exec tsx stress-test/scripts/stress-checkout-providers.ts",
    "preflight:checkout-payment-matrix": "pnpm exec tsx stress-test/scripts/preflight-checkout-payment-matrix.ts",
    "test:e2e": "node stress-test/scripts/run-e2e.js",
    "test:e2e:smoke": "node stress-test/scripts/run-e2e.js --grep @smoke",
    "test:e2e:workflow": "node stress-test/scripts/run-e2e.js --grep @workflow",
    "test:e2e:checkout": "node stress-test/scripts/run-e2e.js stress-test/e2e/workflows/checkout-harness.spec.ts stress-test/e2e/flows/full-commerce-journey.spec.ts stress-test/e2e/flows/medusa-checkout-flow.spec.ts",
    "test:e2e:admin": "node stress-test/scripts/run-e2e.js --grep @admin",
    "test:e2e:matrix": "node stress-test/scripts/run-e2e.js stress-test/e2e/components stress-test/e2e/layouts",
    "test:e2e:chaos": "node stress-test/scripts/run-e2e.js stress-test/e2e/workflows/chaos-network.spec.ts",
    "test:e2e:cross-app": "node stress-test/scripts/run-e2e.js stress-test/e2e/workflows/cross-app-sync.spec.ts",
    "test:e2e:parallel": "node stress-test/scripts/run-e2e.js --workers=4",
    "test:e2e:critical": "node stress-test/scripts/run-e2e.js stress-test/e2e/flows/full-commerce-journey.spec.ts stress-test/e2e/flows/psp-checkout-cod.spec.ts stress-test/e2e/smoke/storefront-api-security.spec.ts stress-test/e2e/smoke/admin-access.spec.ts",
    "test:e2e:ui": "node stress-test/scripts/run-e2e.js --ui",
    "dogfood:screenshots": "node stress-test/scripts/run-e2e.js dogfood --project=chromium",
    "predeploy": "pnpm install && pnpm run build",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "vercel": "^50.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@next/eslint-plugin-next": "^15.0.0",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/parser": "^8.18.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "prettier": "^3.2.5",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0"
  },
  "pnpm": {
    "overrides": {
      "path-scurry>lru-cache": "10.4.3",
      "@vercel/node>path-to-regexp": "6.3.0",
      "@vercel/node>undici": "6.24.0",
      "@vercel/redwood>path-to-regexp": "6.3.0",
      "@vercel/routing-utils>path-to-regexp": "6.3.0",
      "@vercel/fun>tar": "7.5.11",
      "@vercel/fun>semver": "7.6.3",
      "@mapbox/node-pre-gyp>tar": "7.5.11",
      "micromatch>picomatch": "2.3.2",
      "tinyglobby>picomatch": "4.0.4"
    }
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": "20.x"
  }
}
