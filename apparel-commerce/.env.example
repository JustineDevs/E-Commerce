# Database (Supabase) - https://supabase.com/dashboard → Connect → Connection string
# Use Session pooler (port 5432) or Transaction pooler (port 6543) for IPv4. Direct connection requires IPv6.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth - https://next-auth.js.org: generate secret with `openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth - https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Lemon Squeezy - https://app.lemonsqueezy.com/settings/api → API key, Store ID; Webhooks → signing secret
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# AfterShip - https://www.aftership.com → Account → API → create key; Webhooks → secret
AFTERSHIP_API_KEY=
AFTERSHIP_WEBHOOK_SECRET=

# API - base URL for the Node.js API server (server-side)
API_URL=http://localhost:4000
# Next.js client-side fetch (storefront, admin)
NEXT_PUBLIC_API_URL=http://localhost:4000

CORS_ORIGIN=http://localhost:3000 # Your domain or localhost