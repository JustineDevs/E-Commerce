# Database (Supabase) - https://supabase.com/dashboard → Connect → Connection string
# Use Session pooler (port 5432) or Transaction pooler (port 6543) for IPv4. Direct connection requires IPv6.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth - https://next-auth.js.org: generate secret with `openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth - https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Lemon Squeezy - https://app.lemonsqueezy.com/settings/api → API key, Store ID; Webhooks → signing secret
# Create one “pay what you want” or fixed-price variant used only for cart checkouts; put its variant ID here.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_CHECKOUT_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Cart stock reservation TTL (minutes) before checkout must complete
RESERVATION_TTL_MINUTES=30

# Compliance job: anonymize addresses on orders older than this many days (default 730)
DATA_RETENTION_DAYS=730

# AfterShip - https://www.aftership.com → Account → API → create key; Webhooks → secret
AFTERSHIP_API_KEY=
AFTERSHIP_WEBHOOK_SECRET=

# API - base URL for the Node.js API server (server-side)
# Health: GET /health returns 503 when the database is unreachable — use for dependency probes, not generic uptime.
API_URL=http://localhost:4000
# Shared secret for server-to-server calls (storefront SSR, admin SSR, admin BFF). Required in production.
INTERNAL_API_KEY=generate-with-openssl-rand-hex-32

# HMAC secret for public order tracking links (/public/orders, /track?t=…). Required in production (API refuses to start without it).
TRACKING_LINK_SECRET=generate-with-openssl-rand-hex-32

# Checkout rate limits (per IP): short burst window and 15-minute cap
CHECKOUT_BURST_PER_MIN=8
CHECKOUT_MAX_PER_15MIN=30
# Server-minted checkout session (GET /checkout/intent) per IP per minute
CHECKOUT_INTENT_PER_MIN=24
# Intent TTL seconds (60–900; default 300)
CHECKOUT_INTENT_TTL_SECONDS=300
# Optional dedicated HMAC secret for checkout intents; defaults to TRACKING_LINK_SECRET chain
CHECKOUT_INTENT_SECRET=

# Behind nginx/Cloudflare/Vercel: set so express-rate-limit and req.ip use the real client (OWASP A05)
TRUST_PROXY=false

# GET /public/orders/:id — requests per IP per minute
PUBLIC_TRACK_RATE_MAX=60

# Next.js client-side fetch (storefront, admin; public catalog only)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Canonical site URL for Open Graph / metadataBase (production: https://your-domain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public storefront origin used by the API for absolute links (e.g. Resend tracking URLs). Defaults to NEXT_PUBLIC_SITE_URL in docs; set explicitly if API generates emails and SITE_URL differs.
PUBLIC_STOREFRONT_URL=http://localhost:3000

# Resend — https://resend.com → API Keys; verify a sending domain; From must use verified domain in production
RESEND_API_KEY=
# e.g. orders@notify.yourdomain.com
RESEND_FROM_EMAIL=
# Display name / brand line in checkout emails (default: Maharlika Apparel Custom)
RESEND_BRAND_NAME=Maharlika Apparel Custom

# Storefront (public) — see internal/docs/SKILLS-RUNBOOK.md
# Footer Instagram link (omit to hide). Full https URL, or @handle / handle for instagram.com
NEXT_PUBLIC_INSTAGRAM_URL=
# Comma-separated hostname patterns for remote product images (next.config remotePatterns). Default in code includes Supabase-style hosts if unset.
NEXT_PUBLIC_IMAGE_HOSTNAMES=**.supabase.co
# Contact page + mailto (required for “Open in email app”)
NEXT_PUBLIC_SUPPORT_EMAIL=
# Optional display / tel: link on Contact
NEXT_PUBLIC_SUPPORT_PHONE=

# Comma-separated browser origins allowed to call the API (include storefront + admin dev ports)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Admin app: restrict Google sign-in to these emails (comma-separated). Required in production.
ADMIN_ALLOWED_EMAILS=you@company.com

# --- Medusa 2.x (apps/medusa) — dedicated Postgres; do NOT point at legacy custom schema without migration ---
# Copy detailed template from apps/medusa/.env.template; minimum:
# MEDUSA_DATABASE_URL=postgresql://user:pass@host:5432/medusa_v2
# Or set DATABASE_URL inside apps/medusa/.env only (see Medusa docs)

# Storefront: use Medusa Store API as catalog + checkout (Lemon via Medusa payment module)
# legacy | medusa — default legacy. Set medusa when Medusa is seeded and publishable key + region exist.
NEXT_PUBLIC_COMMERCE_SOURCE=legacy
# Medusa HTTP base (browser + SSR). Example: http://localhost:9000
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
# Optional server-only override for catalog SSR (same origin as Store API)
# MEDUSA_BACKEND_URL=http://localhost:9000
# Publishable key from Medusa Admin (Sales channel / API keys). Use MEDUSA_* on server-only builds if preferred.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
MEDUSA_PUBLISHABLE_API_KEY=
# Philippines region id from Medusa (e.g. reg_...)
NEXT_PUBLIC_MEDUSA_REGION_ID=
MEDUSA_REGION_ID=
# Payment session provider id (Lemon module): pp_lemonsqueezy_lemonsqueezy
NEXT_PUBLIC_MEDUSA_PAYMENT_PROVIDER_ID=pp_lemonsqueezy_lemonsqueezy

# Legacy Express commerce API: return 410 for commerce routes when enabled (see apps/api LEGACY_COMMERCE_API_DISABLED)
# LEGACY_COMMERCE_API_DISABLED=true

# AfterShip (Medusa): subscriber + /hooks/aftership — see apps/medusa/.env.template
# AFTERSHIP_COURIER_SLUG=jtexpress-ph