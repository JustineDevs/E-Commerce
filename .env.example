# Root .env — single source of truth for storefront, admin, Express API, and Medusa.
# Copy to `.env` at this repo root. Optional local overrides: root `.env.local` (gitignored). Do not use `apps/admin/.env.local`.
# Production: replace http://localhost:* in site URLs and CORS lists with your public HTTPS origins.
# Generate secrets: openssl rand -base64 32 (JWT/COOKIE/NEXTAUTH/TRACKING) or openssl rand -hex 32 (INTERNAL_API_KEY, CHANNEL_WEBHOOK).
# Storefront (temporary Vercel): https://maharlika-apparel-custom.vercel.app
NODE_ENV=production
# =============================================================================
# 1. App URLs
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_STOREFRONT_URL=http://localhost:3000
API_URL=http://localhost:4000

# =============================================================================
# 2. NextAuth
# =============================================================================
# Storefront / default callback base (port 3000).
NEXTAUTH_URL=http://localhost:3000
# Staff admin on port 3001: required for Google OAuth redirect to hit the admin app (maps to NEXTAUTH_URL inside admin only).
ADMIN_NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=

# =============================================================================
# 3. Google OAuth
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# 4. Supabase (platform DB, RBAC, CMS) pnpm --filter @apparel-commerce/database migrate
# =============================================================================
LEGACY_DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_IMAGE_HOSTNAMES=**.supabase.co

# =============================================================================
# 5. Express internal API
# =============================================================================
INTERNAL_API_KEY=

# =============================================================================
# 6. Express CORS
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# =============================================================================
# 7. GDPR retention
# =============================================================================
DATA_RETENTION_DAYS=730

# =============================================================================
# 8. Admin
# =============================================================================
# ADMIN_NEXTAUTH_URL is listed under NextAuth (section 2) for OAuth on port 3001.
ADMIN_ALLOWED_EMAILS=
NEXT_PUBLIC_STAFF_RBAC_STRICT=true
CHANNEL_WEBHOOK_SECRET=
# When true, POS online sales require an open shift and shiftId on commit-sale (register-grade).
POS_SALE_REQUIRES_OPEN_SHIFT=false

# =============================================================================
# 9. Medusa client (storefront and admin) `pnpm --filter medusa seed:ph` and `pnpm --filter medusa dev`
# =============================================================================
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_REGION_ID=
NEXT_PUBLIC_MEDUSA_SALES_CHANNEL_ID=
NEXT_PUBLIC_MEDUSA_PAYMENT_PROVIDER_ID=pp_stripe_stripe
NEXT_PUBLIC_CHECKOUT_PAYMENT_PROVIDERS=STRIPE,PAYPAL,PAYMONGO,MAYA,COD

MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_PUBLISHABLE_API_KEY=
MEDUSA_REGION_ID=
MEDUSA_SALES_CHANNEL_ID=
MEDUSA_SECRET_API_KEY=

# =============================================================================
# 10. Medusa server (run `pnpm --filter medusa exec medusa db:migrate` to apply migrations)
# =============================================================================
JWT_SECRET=`openssl rand -hex 32`
COOKIE_SECRET=`openssl rand -hex 32`
DATABASE_URL=
DB_NAME=medusa-v2

# =============================================================================
# 11. Redis (Medusa cache / events, or Upstash REST for serverless) `https://upstash.com`
# =============================================================================
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# 12. Medusa CORS
# =============================================================================
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3001,http://localhost:9000
AUTH_CORS=http://localhost:3001,http://localhost:9000
STOREFRONT_PUBLIC_URL=http://localhost:3000

# Storefront: GET /api/cron/finalize-payment-attempts (Bearer token or x-cron-secret header)
STOREFRONT_PAYMENT_CRON_SECRET= # openssl rand -hex 32
# When true, POST /api/checkout/complete-medusa-cart requires a payment_attempt correlationId (strict ledger path)
STOREFRONT_STRICT_PAYMENT_LEDGER=false
# Shared secret for POST /api/internal/reconcile-payment-attempt (admin retry, automation). openssl rand -hex 32
STOREFRONT_INTERNAL_RECONCILE_SECRET=

# Admin (server): base URL of the storefront for payment retry finalization (same host as customers use)
STOREFRONT_ORIGIN=http://localhost:3000

# =============================================================================
# 13. Medusa payment providers (set on the Medusa process; restart Medusa after changes) check `./docs/runbooks/GUIDE.md`
# =============================================================================
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_FALLBACK_CURRENCY=php
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=sandbox
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
MAYA_SECRET_KEY=
MAYA_WEBHOOK_SECRET=
MAYA_SANDBOX=true
AFTERSHIP_API_KEY=
AFTERSHIP_WEBHOOK_SECRET=
AFTERSHIP_COURIER_SLUG=jtexpress-ph

STRIPE_CHECKOUT_SUCCESS_URL=https://localhost:3000/checkout/stripe-return?stripe_session={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://localhost:3000/checkout?stripe_cancel=1

# =============================================================================
# 15. Resend and signed tracking links (Medusa requires TRACKING_HMAC_SECRET `openssl rand -hex 32` when `https://resend.com/api-keys` is set in production)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=<contact@maharlika.store>
RESEND_BRAND_NAME="Maharlika Apparel Custom"
TRACKING_HMAC_SECRET=
