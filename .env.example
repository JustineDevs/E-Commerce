# Temporary public storefront (Vercel preview):
#   https://maharlika-apparel-custom.vercel.app
# Local dev: use http://localhost:3000 for URLs below instead.
# =========================================================

# ---------------------------------------------------------
# App URLs
# ---------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://maharlika-apparel-custom.vercel.app
PUBLIC_STOREFRONT_URL=https://maharlika-apparel-custom.vercel.app
API_URL=http://localhost:4000

# ---------------------------------------------------------
# NextAuth (admin + storefront auth)
# Generate secret: openssl rand -base64 32
# Must be a single URL matching where the app runs.
# Local dev: http://localhost:3000 (storefront) or http://localhost:3001 (admin)
# Vercel: https://maharlika-apparel-custom.vercel.app
# ---------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ---------------------------------------------------------
# Google OAuth
# Google Cloud Console > APIs & Services > Credentials
# Authorized JavaScript origins: http://localhost:3000, http://localhost:3001
# Authorized redirect URIs (both apps share the same OAuth client):
#   http://localhost:3000/api/auth/callback/google   (storefront)
#   http://localhost:3001/api/auth/callback/google   (admin)
# Admin: apps/admin/.env.local overrides NEXTAUTH_URL to http://localhost:3001
# ---------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------
# Legacy user database (Supabase)
# Supabase dashboard > Settings > API for URL and keys.
# Used for admin auth (upsertOAuthUser) and GDPR compliance.
# ---------------------------------------------------------
# Supabase Postgres connection (pooler URI from Dashboard > Project Settings > Database).
# Required for: pnpm --filter @apparel-commerce/database migrate (applies SQL in packages/database/supabase/migrations without the Supabase CLI).
LEGACY_DATABASE_URL=
SUPABASE_URL=
# Anon key: required on the storefront app so the home page and full CMS (pages, nav, blog, redirects, etc.) can load public copy via RLS.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Storefront server routes (reviews POST, cart abandonment POST) use the service role. Migrations: packages/database/supabase/migrations (e.g. 008_storefront_reviews_cart.sql).
# Apply platform SQL migrations (no global CLI needed if LEGACY_DATABASE_URL is set):
#   pnpm --filter @apparel-commerce/database migrate
# Optional: if you install the Supabase CLI, you can use `migrate:cli` instead of the script above.

# ---------------------------------------------------------
# Internal API security (Express health/compliance)
# Generate: openssl rand -hex 32
# ---------------------------------------------------------
INTERNAL_API_KEY=

# ---------------------------------------------------------
# Express CORS — include Vercel storefront + local dev
# ---------------------------------------------------------
CORS_ORIGIN=https://maharlika-apparel-custom.vercel.app,http://localhost:3000,http://localhost:3001

# ---------------------------------------------------------
# GDPR compliance
# ---------------------------------------------------------
DATA_RETENTION_DAYS=730

# ---------------------------------------------------------
# Local POS hardware (terminal-agent on each register)
# Run: pnpm --filter @apparel-commerce/terminal-agent dev
# Default URL is http://127.0.0.1:17711 (browser calls this after Medusa sale).
# require X-Terminal-Agent-Secret on POST /print-receipt and /open-drawer.
# When set, admin POS should use server proxy: NEXT_PUBLIC_TERMINAL_PRINT_VIA_API=true
# and set TERMINAL_AGENT_SECRET (server-only) plus TERMINAL_AGENT_URL for the agent base URL.
# ---------------------------------------------------------
NEXT_PUBLIC_TERMINAL_AGENT_URL=http://127.0.0.1:17711
NEXT_PUBLIC_TERMINAL_AGENT_ENABLED=true
NEXT_PUBLIC_TERMINAL_AGENT_ADAPTER=escpos-tcp
NEXT_PUBLIC_TERMINAL_PRINT_VIA_API=
TERMINAL_AGENT_URL=http://127.0.0.1:17711
TERMINAL_AGENT_SECRET= # openssl rand -hex 32
TERMINAL_AGENT_PORT=17711
TERMINAL_DEVICE_NAME= # Leave empty
TERMINAL_DEFAULT_ADAPTER= # Leave empty escpos-tcp, http-relay, qz-tray, epson-epos, star-cloudprnt
PRINTER_TCP_HOST=127.0.0.1
PRINTER_TCP_PORT=9100
TERMINAL_HTTP_RELAY_URL= # Leave empty
QZ_TRAY_RELAY_URL= # Leave empty
EPSON_EPOS_PRINT_URL= # Leave empty
STAR_CLOUDPRNT_TOKEN= # openssl rand -hex 32
TERMINAL_AGENT_MOCK_DIR= # Leave empty
# Production: mock print adapter is blocked unless set to true (emergency only).
# ALLOW_MOCK_TERMINAL_ADAPTER=

# Admin app
# Comma-separated emails promoted to **admin** on each Google sign-in (full back office: role admin + wildcard permission *).
# Matching is case-insensitive. Applies even if the user was previously `staff` in Supabase. After changing this list, sign out and sign in again.
# ---------------------------------------------------------
ADMIN_ALLOWED_EMAILS=you@company.com
# Legacy env; RBAC is role-based (admin = *, staff = grant rows). Optional for tooling that still reads it.
NEXT_PUBLIC_STAFF_RBAC_STRICT=true
# generate: openssl rand -hex 32. Required on Vercel production and on self-hosted NODE_ENV=production.
# Send x-channel-signature: hex(HMAC-SHA256(raw body, secret)).
CHANNEL_WEBHOOK_SECRET=
# generate: openssl rand -hex 32. Server-to-server POST /api/integrations/chat-orders/intake via x-internal-key.
INTERNAL_CHAT_INTAKE_KEY=

# ---------------------------------------------------------
# Medusa client (app > Medusa HTTP API)
# Browser-safe: NEXT_PUBLIC_*. Server-only: MEDUSA_* without NEXT_PUBLIC_*.
# Local: http://localhost:9000 | creating a user: `npx medusa user -e your-email@example.com -p your-password`
# 1. Start Medusa (from repo root)
# pnpm --filter medusa dev
# 2. In another terminal: run the Philippines seed (creates region, sales channel, publishable API key)
# pnpm --filter medusa seed:ph
# ---------------------------------------------------------
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_REGION_ID=
NEXT_PUBLIC_MEDUSA_SALES_CHANNEL_ID=
# Default provider; checkout lets user pick: pp_lemonsqueezy_lemonsqueezy | pp_paymongo_paymongo | pp_maya_maya
NEXT_PUBLIC_MEDUSA_PAYMENT_PROVIDER_ID=pp_lemonsqueezy_lemonsqueezy

MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_PUBLISHABLE_API_KEY=
MEDUSA_REGION_ID=
MEDUSA_SALES_CHANNEL_ID=
MEDUSA_SECRET_API_KEY=
# Storefront server routes (/api/cart/attach-customer) use this to link the HttpOnly cart cookie to a Medusa customer. Never expose in NEXT_PUBLIC_*.
# Production: set REDIS_URL so Medusa uses real Redis. If unset, Medusa may use in-memory Redis (dev-only; not for multi-instance prod).
# REDIS_URL=
# Loyalty checkout: dedicated product variant id for custom negative line items (see Medusa /store/carts/:id/loyalty).
MEDUSA_LOYALTY_DISCOUNT_VARIANT_ID=

# Optional: cron / medusa exec for polling stuck Maya payments (see apps/medusa/src/scripts/reconcile-pending-payments.ts). Requires MAYA_SECRET_KEY.
# MEDUSA_RECONCILE_MINUTES=30

# ---------------------------------------------------------
# Storefront observability (optional)
# ---------------------------------------------------------
# Sentry: errors and performance. Set NEXT_PUBLIC_SENTRY_DSN for browser + Node.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
# Source maps upload (CI): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT

# LogSnag: server-side events from API routes (e.g. cart merge). https://logsnag.com
# LOGSNAG_TOKEN=
# LOGSNAG_PROJECT=

# ---------------------------------------------------------
# Tracking link HMAC (spec: scoped secret for anonymous tracking)
# Generate: openssl rand -base64 32
# Required when TRACKING_HMAC_SECRET is set in Medusa (order-placed email).
# Storefront and Medusa must share the same value.
# ---------------------------------------------------------
TRACKING_HMAC_SECRET=

# ---------------------------------------------------------
# Public storefront metadata
# ---------------------------------------------------------
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_IMAGE_HOSTNAMES=**.supabase.co
# Optional: Microsoft Clarity project ID (heatmaps and session replay on the storefront).
NEXT_PUBLIC_CLARITY_PROJECT_ID=
