# =========================================================
# MEDUSA — commerce backend process only
#
# Owns: DATABASE_URL (commerce Postgres), REDIS_URL, JWT_SECRET, COOKIE_SECRET,
# STORE_CORS / ADMIN_CORS / AUTH_CORS, and commerce integrations below.
#
# Do not duplicate Lemon / AfterShip / Resend in the root .env.example — configure here only.
# Root app: NextAuth, Google OAuth, UI URLs, LEGACY_DATABASE_URL, Supabase keys, Medusa client URLs.
#
# Storefront (temporary Vercel): https://maharlika-apparel-custom.vercel.app
# =========================================================

# ---------------------------------------------------------
# HTTP / CORS
# ---------------------------------------------------------
# Comma-separated origins allowed to call Medusa (HTTPS in production).
# Include the Vercel storefront + local dev.
STORE_CORS=https://maharlika-apparel-custom.vercel.app,http://localhost:3000
ADMIN_CORS=http://localhost:3001,http://localhost:9000,https://maharlika-apparel-custom.vercel.app
AUTH_CORS=http://localhost:3001,http://localhost:9000,https://maharlika-apparel-custom.vercel.app

# ---------------------------------------------------------
# Medusa session secrets
# ---------------------------------------------------------
# openssl rand -base64 32 (each). Never ship defaults to production.
JWT_SECRET=
COOKIE_SECRET=

# ---------------------------------------------------------
# Commerce database (Medusa Postgres only)
# ---------------------------------------------------------
DATABASE_URL=
DB_NAME=medusa-v2

# ---------------------------------------------------------
# Redis
# ---------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Store API rate limit (middleware on /store/*) — requests per IP per minute window
# MEDUSA_STORE_RATE_LIMIT_MAX=120

# ---------------------------------------------------------
# Lemon Squeezy
# ---------------------------------------------------------
# https://app.lemonsqueezy.com/settings/api — API key, Store ID, variant ID, webhook signing secret
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_CHECKOUT_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ---------------------------------------------------------
# AfterShip
# ---------------------------------------------------------
# https://admin.aftership.com — API key; webhook signing secret; courier slug for your carrier
AFTERSHIP_API_KEY=
AFTERSHIP_WEBHOOK_SECRET=
AFTERSHIP_COURIER_SLUG=jtexpress-ph

# ---------------------------------------------------------
# Resend (order emails from Medusa)
# ---------------------------------------------------------
# https://resend.com/api-keys — verify sending domain for production
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_BRAND_NAME=Maharlika Apparel Custom
STOREFRONT_PUBLIC_URL=https://maharlika-apparel-custom.vercel.app
