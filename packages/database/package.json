{
  "name": "@apparel-commerce/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "migrate": "tsx scripts/run-migrations.ts",
    "migrate:cli": "supabase db push",
    "seed": "tsx scripts/seed.ts",
    "apply-rls": "tsx scripts/apply-sql.ts supabase/migrations/enable_rls.sql",
    "lint": "eslint src --ext .ts",
    "test": "node --import tsx/esm --test src/compliance.test.ts"
  },
  "dependencies": {
    "@apparel-commerce/platform-data": "workspace:*",
    "@apparel-commerce/types": "workspace:*",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@apparel-commerce/config-eslint": "workspace:*",
    "@apparel-commerce/config-typescript": "workspace:*",
    "@types/pg": "^8.11.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "pg": "^8.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
